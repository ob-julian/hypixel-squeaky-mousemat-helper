{
	"schemaVersion": 1,
	"id": "hypixel-squeaky-mousemat-helper",
	"version": "${version}",
	"name": "Hypixel Squeaky Mousemat Helper",
	"description": "A Hypixel SkyBlock QoL mod that color-codes your hotbar Squeaky Mousemats from green to red based on how closely they match your current player rotation.",
	"authors": [
		"Julian"
	],
	"contact": {
		"sources": "https://github.com/ob-julian/hypixel-squeaky-mousemat-helper"
	},
	"license": "CC0-1.0",
	"icon": "assets/hypixel-squeaky-mousemat-helper/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"value": "julian.mousemat.HypixelSqueakyMousematHelper",
				"adapter": "kotlin"
			}
		]
	},
	"depends": {
		"fabricloader": ">=0.18.0",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}